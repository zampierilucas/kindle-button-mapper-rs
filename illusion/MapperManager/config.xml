<?xml version="1.0" encoding="UTF-8"?>
<widget id="com.lzampier.mappermanager" version="1.0" viewmodes="application"
        xmlns="http://www.w3.org/ns/widgets"
        xmlns:kindle="http://kindle.amazon.com/ns/widget-extensions">

    <name xml:lang="en">Button Mapper</name>
    <author>Lucas Zampieri</author>
    <description xml:lang="en">Map Kindle buttons to actions</description>

    <content src="index.html" />

    <kindle:chrome>
        <kindle:asset key="configureSearchBar" value="system" />
    </kindle:chrome>

    <kindle:gestures>
        <kindle:param name="tap" value="yes" properties="fire_on_tap:1" />
        <kindle:param name="swipe" value="yes" />
    </kindle:gestures>

    <feature name="http://kindle.amazon.com/apis" required="true">
        <param name="appmgr" value="yes" />
        <param name="gestures" value="yes" />
        <param name="messaging" value="yes" />
        <param name="device" value="yes" />
        <param name="chrome" value="yes" />
    </feature>

    <kindle:messaging>
        <kindle:app name="com.lab126.pillow" value="yes" />
        <kindle:app name="com.lab126.chromebar" value="yes" />
    </kindle:messaging>

    <kindle:resources>
        <kindle:asset key="LocalStorageQuota" value="5242880" />
    </kindle:resources>

    <kindle:settings>
        <kindle:setting name="internetRequired" value="no" />
        <kindle:setting name="saveContext" value="no" />
    </kindle:settings>

</widget>
